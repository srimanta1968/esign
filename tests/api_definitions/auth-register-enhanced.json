{
  "endpoint": "/api/auth/register",
  "method": "POST",
  "taskId": "a6e870c2-44c6-4263-92a5-40e478042677",
  "requiresAuth": false,
  "priority": 1,
  "dependsOn": [],
  "captureResponse": {
    "auth.register.response.data.token": "data.token",
    "auth.register.response.data.user.id": "data.user.id",
    "auth.register.response.data.user.email": "data.user.email",
    "auth.register.response.data.user.name": "data.user.name",
    "auth.register.response.data.user.role": "data.user.role"
  },
  "testCases": [
    {
      "name": "Register a new user with name and role",
      "headers": {
        "Content-Type": "application/json"
      },
      "payload": {
        "email": "{{dynamic:email}}",
        "password": "Test@1234",
        "name": "Test User",
        "role": "user"
      },
      "expectedStatus": 201,
      "expectedResponse": {
        "success": true,
        "data": {
          "token": "string",
          "user": {
            "id": "string",
            "email": "string",
            "name": "string",
            "role": "string"
          }
        }
      }
    },
    {
      "name": "Reject invalid email format",
      "headers": {
        "Content-Type": "application/json"
      },
      "payload": {
        "email": "invalid-email",
        "password": "Test@1234"
      },
      "expectedStatus": 400,
      "expectedResponse": {
        "success": false,
        "error": "string"
      }
    },
    {
      "name": "Reject weak password",
      "headers": {
        "Content-Type": "application/json"
      },
      "payload": {
        "email": "{{dynamic:email}}",
        "password": "weak"
      },
      "expectedStatus": 400,
      "expectedResponse": {
        "success": false,
        "error": "string"
      }
    },
    {
      "name": "Reject duplicate email with 409",
      "headers": {
        "Content-Type": "application/json"
      },
      "payload": {
        "email": "{{cache:auth.register.response.data.user.email}}",
        "password": "Test@1234"
      },
      "expectedStatus": 409,
      "expectedResponse": {
        "success": false,
        "error": "Email already registered"
      }
    }
  ]
}
