{
  "endpoint": "/api/auth/sessions/:id",
  "method": "DELETE",
  "taskId": "75c9b422-947c-4a41-b3d4-087cff1f0285",
  "requiresAuth": true,
  "priority": 14,
  "dependsOn": ["GET /api/auth/sessions"],
  "testCases": [
    {
      "name": "Revoke a session by ID",
      "headers": {
        "Authorization": "Bearer {{captured:auth.refreshToken.response.data.token}}"
      },
      "urlParams": {
        "id": "{{captured:auth.refreshToken.response.data.session.id}}"
      },
      "expectedStatus": 200,
      "expectedResponse": {
        "success": true,
        "data": {
          "message": "Session revoked successfully"
        }
      }
    },
    {
      "name": "Return 404 for non-existing session",
      "headers": {
        "Authorization": "Bearer {{captured:auth.refreshToken.response.data.token}}"
      },
      "urlParams": {
        "id": "00000000-0000-0000-0000-000000000000"
      },
      "expectedStatus": 404,
      "expectedResponse": {
        "success": false,
        "error": "Session not found"
      }
    }
  ]
}
