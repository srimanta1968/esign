{
  "endpoint": "/api/analytics/signature-event",
  "method": "POST",
  "taskId": "a9068772-e635-4386-bea3-f141a08245bd",
  "requiresAuth": true,
  "priority": 30,
  "dependsOn": ["POST /api/auth/register"],
  "testCases": [
    {
      "name": "Track a signature engagement event",
      "headers": {
        "Authorization": "Bearer {{cache:auth.register.response.data.token}}",
        "Content-Type": "application/json"
      },
      "payload": {
        "event_type": "signature_viewed",
        "metadata": {
          "document_id": "test-doc-123",
          "duration_ms": 5000
        }
      },
      "expectedStatus": 201,
      "expectedResponse": {
        "success": true,
        "data": {
          "event": {
            "id": "string",
            "event_type": "signature_viewed",
            "user_id": "string",
            "metadata": "object",
            "created_at": "string"
          }
        }
      }
    },
    {
      "name": "Fail without event_type",
      "headers": {
        "Authorization": "Bearer {{cache:auth.register.response.data.token}}",
        "Content-Type": "application/json"
      },
      "payload": {
        "metadata": {}
      },
      "expectedStatus": 400,
      "expectedResponse": {
        "success": false,
        "error": "string"
      }
    }
  ]
}
