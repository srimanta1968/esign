{
  "endpoint": "/api/documents",
  "method": "POST",
  "taskId": "ad4ab56b-fb79-4d6e-9ab7-e598befdf828",
  "requiresAuth": true,
  "priority": 10,
  "dependsOn": ["POST /api/auth/register"],
  "captureResponse": {
    "documents.create.response.data.document.id": "data.document.id"
  },
  "testCases": [
    {
      "name": "Upload a document",
      "headers": {
        "Authorization": "Bearer {{cache:auth.register.response.data.token}}",
        "Content-Type": "application/json"
      },
      "payload": {
        "file_path": "{{dynamic:text}}",
        "original_name": "{{dynamic:text}}"
      },
      "expectedStatus": 201,
      "expectedResponse": {
        "success": true,
        "data": {
          "document": {
            "id": "string",
            "user_id": "string",
            "file_path": "string",
            "uploaded_at": "string"
          }
        }
      }
    }
  ]
}
