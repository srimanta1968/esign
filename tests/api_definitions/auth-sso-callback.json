        "code": "test-auth-code",
        "state": "google"
      },
      "expectedStatus": 400,
      "expectedResponse": {
        "success": false,
        "error": "Failed to exchange authorization code"
      }
    },
    {
      "name": "Reject callback without authorization code",
      "queryParams": {},
      "expectedStatus": 400,
      "expectedResponse": {
        "success": false,
        "error": "Authorization code is required"
      }
    }
  ]
}
