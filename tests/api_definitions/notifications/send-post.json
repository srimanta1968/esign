{
  "name": "POST /api/notifications/send - Send notification",
  "endpoint": "/api/notifications/send",
  "method": "POST",
  "requiresAuth": true,
  "expectedStatus": 200,
  "priority": 17,
  "testCases": [
    {
      "name": "Send in-app notification to self",
