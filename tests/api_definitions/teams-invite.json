{
  "name": "POST /api/teams/:id/invite - Invite members",
  "endpoint": "/api/teams/{{cache:teams.create.response.data.id}}/invite",
  "method": "POST",
  "requiresAuth": true,
  "expectedStatus": 200,
  "taskId": "9927c6cb-2af2-438a-b9cd-f7f35ff9e6a2",
  "sprintId": "729f9fe5-b963-4444-8b0e-f82bd555d110",
  "testCases": [
    {
      "name": "Invite new member emails",
      "payload": {
        "emails": ["invitee_{{timestamp}}@example.com"]
      },
      "expectedStatus": 200,
      "headers": {
        "Authorization": "Bearer {{cache:auth.login.response.data.token}}"
      }
    },
    {
      "name": "Missing emails returns 400",
      "payload": {},
      "expectedStatus": 400,
      "headers": {
        "Authorization": "Bearer {{cache:auth.login.response.data.token}}"
      }
    }
  ],
  "dependsOn": ["POST /api/auth/register", "POST /api/auth/login", "POST /api/teams"]
}
