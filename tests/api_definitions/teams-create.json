{
  "name": "POST /api/teams - Create team",
  "endpoint": "/api/teams",
  "method": "POST",
  "requiresAuth": true,
  "expectedStatus": 201,
  "taskId": "9927c6cb-2af2-438a-b9cd-f7f35ff9e6a2",
  "sprintId": "729f9fe5-b963-4444-8b0e-f82bd555d110",
  "testCases": [
    {
      "name": "Create a team",
      "payload": {
        "name": "Test Team {{timestamp}}",
        "plan": "team"
      },
      "expectedStatus": 201,
      "headers": {
        "Authorization": "Bearer {{cache:auth.login.response.data.token}}"
      }
    },
    {
      "name": "Missing name returns 400",
      "payload": {},
      "expectedStatus": 400,
      "headers": {
        "Authorization": "Bearer {{cache:auth.login.response.data.token}}"
      }
    }
  ],
  "captureResponse": {
    "teams.create.response.data.id": "team.id"
  },
  "dependsOn": ["POST /api/auth/register", "POST /api/auth/login"]
}
