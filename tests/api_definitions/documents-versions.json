{
  "endpoints": [
    {
      "endpoint": "/api/documents/:id/versions",
      "method": "POST",
      "taskId": "4cd3dcb1-4c46-4446-9d0b-9fd98d1a2480",
      "requiresAuth": true,
      "priority": 11,
      "dependsOn": ["POST /api/documents"],
      "description": "Upload a new version of a document",
      "testCases": [
        {
          "name": "Upload new document version",
          "headers": {
            "Authorization": "Bearer {{cache:auth.register.response.data.token}}",
            "Content-Type": "multipart/form-data"
          },
          "payload": {
            "file": "{{dynamic:file}}"
          },
          "expectedStatus": 201,
          "expectedResponse": {
            "success": true,
            "data": {
              "version": {
                "id": "string",
                "document_id": "string",
                "version_number": "number",
                "file_path": "string",
                "file_size": "number",
                "created_by": "string",
                "created_at": "string"
              }
            }
          }
        }
      ]
    },
    {
      "endpoint": "/api/documents/:id/versions",
      "method": "GET",
      "taskId": "4cd3dcb1-4c46-4446-9d0b-9fd98d1a2480",
      "requiresAuth": true,
      "priority": 11,
      "dependsOn": ["POST /api/documents"],
      "description": "List all versions of a document",
      "testCases": [
        {
          "name": "List document versions",
          "headers": {
            "Authorization": "Bearer {{cache:auth.register.response.data.token}}"
          },
          "expectedStatus": 200,
          "expectedResponse": {
            "success": true,
            "data": {
              "versions": "array"
            }
          }
        }
      ]
    },
    {
      "endpoint": "/api/documents/:id/versions/:versionId/revert",
      "method": "POST",
      "taskId": "4cd3dcb1-4c46-4446-9d0b-9fd98d1a2480",
      "requiresAuth": true,
      "priority": 12,
      "dependsOn": ["POST /api/documents/:id/versions"],
      "description": "Revert document to a specific version",
      "testCases": [
        {
          "name": "Revert to a previous version",
          "headers": {
            "Authorization": "Bearer {{cache:auth.register.response.data.token}}"
          },
          "expectedStatus": 200,
          "expectedResponse": {
            "success": true,
            "data": {
              "version": {
                "id": "string",
                "document_id": "string",
                "version_number": "number",
                "file_path": "string",
                "file_size": "number",
                "created_by": "string",
                "created_at": "string"
              }
            }
          }
        },
        {
          "name": "Revert to non-existent version returns 404",
          "headers": {
            "Authorization": "Bearer {{cache:auth.register.response.data.token}}"
          },
          "expectedStatus": 404,
          "expectedResponse": {
            "success": false,
            "error": "string"
          }
        }
      ]
    }
  ]
}
