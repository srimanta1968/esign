{
  "endpoint": "/api/user-signatures",
  "method": "POST",
  "taskId": "935f9534-4faf-403d-879b-eca24e5ea85b",
  "requiresAuth": true,
  "priority": 30,
  "dependsOn": ["POST /api/auth/register"],
  "captureResponse": {
    "userSignatures.createTyped.response.data.userSignature.id": "data.userSignature.id"
  },
  "testCases": [
    {
      "name": "Create a typed signature with font_family",
      "headers": {
        "Authorization": "Bearer {{cache:auth.register.response.data.token}}",
        "Content-Type": "application/json"
      },
      "payload": {
        "signature_type": "typed",
        "signature_data": "John Doe",
        "font_family": "Dancing Script"
      },
      "expectedStatus": 201,
      "expectedResponse": {
        "success": true,
        "data": {
          "userSignature": {
            "id": "string",
            "user_id": "string",
            "signature_type": "typed",
            "signature_data": "string",
            "font_family": "string"
          }
        }
      }
    },
    {
      "name": "Fail to create typed signature without font_family",
      "headers": {
        "Authorization": "Bearer {{cache:auth.register.response.data.token}}",
        "Content-Type": "application/json"
      },
      "payload": {
        "signature_type": "typed",
        "signature_data": "John Doe"
      },
      "expectedStatus": 400,
      "expectedResponse": {
        "success": false,
        "error": "string"
      }
    },
    {
      "name": "Fail to create uploaded signature without file",
      "headers": {
        "Authorization": "Bearer {{cache:auth.register.response.data.token}}",
        "Content-Type": "application/json"
      },
      "payload": {
        "signature_type": "uploaded"
      },
      "expectedStatus": 400,
      "expectedResponse": {
        "success": false,
        "error": "string"
      }
    }
  ]
}
