{
  "endpoint": "/api/workflows/:id/status",
  "method": "GET",
  "taskId": "145a31aa-6e9c-4834-b373-083839d339ac",
  "requiresAuth": true,
  "priority": 35,
  "dependsOn": ["POST /api/workflows/:id/start"],
  "testCases": [
    {
      "name": "Get real-time status of all signers in a workflow",
      "headers": {
        "Authorization": "Bearer {{cache:auth.register.response.data.token}}"
      },
      "urlParams": {
        "id": "{{cache:workflows.create.response.data.workflow.id}}"
      },
      "expectedStatus": 200,
      "expectedResponse": {
        "success": true,
        "data": {
          "status": {
            "workflow_id": "string",
            "workflow_type": "string",
            "status": "string",
            "recipients": "array",
            "progress": {
              "total": "number",
              "signed": "number",
              "pending": "number",
              "declined": "number"
            }
          }
        }
      }
    }
  ]
}
