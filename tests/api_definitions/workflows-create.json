{
  "endpoint": "/api/workflows",
  "method": "POST",
  "taskId": "c49c5e95-5e92-4d5d-adb6-9c9ccc99c2bf",
  "requiresAuth": true,
  "priority": 30,
  "dependsOn": ["POST /api/auth/register", "POST /api/documents"],
  "captureResponse": {
    "workflows.create.response.data.workflow.id": "data.workflow.id"
  },
  "testCases": [
    {
      "name": "Create a signing workflow with recipients",
      "headers": {
        "Authorization": "Bearer {{cache:auth.register.response.data.token}}",
        "Content-Type": "application/json"
      },
      "payload": {
        "document_id": "{{cache:documents.create.response.data.document.id}}",
        "workflow_type": "sequential",
        "recipients": [
          {
            "signer_email": "{{dynamic:email}}",
            "signer_name": "Test Signer 1",
            "signing_order": 1
          },
          {
            "signer_email": "{{dynamic:email}}",
            "signer_name": "Test Signer 2",
            "signing_order": 2
          }
        ],
        "fields": [
          {
            "recipient_index": 0,
            "field_type": "signature",
            "page": 1,
            "x": 100,
            "y": 500,
            "width": 200,
            "height": 50
          }
        ]
      },
      "expectedStatus": 201,
      "expectedResponse": {
        "success": true,
        "data": {
          "workflow": {
            "id": "string",
            "document_id": "string",
            "creator_id": "string",
            "workflow_type": "string",
            "status": "string",
            "recipients": "array",
            "fields": "array",
            "created_at": "string",
            "updated_at": "string"
          }
        }
      }
    }
  ]
}
