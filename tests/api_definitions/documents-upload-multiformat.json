{
  "endpoint": "/api/documents",
  "method": "POST",
  "taskId": "f61babf2-1cda-496f-b3bc-0bc78fe8a20f",
  "requiresAuth": true,
  "priority": 10,
  "dependsOn": ["POST /api/auth/register"],
  "description": "Enhanced document upload supporting PDF, DOCX, XLSX, TXT with file_type, file_size, mime_type detection",
  "testCases": [
    {
      "name": "Upload a PDF document with multi-format support",
      "headers": {
        "Authorization": "Bearer {{cache:auth.register.response.data.token}}",
        "Content-Type": "multipart/form-data"
      },
      "payload": {
        "file": "{{dynamic:file}}"
      },
      "expectedStatus": 201,
      "expectedResponse": {
        "success": true,
        "data": {
          "document": {
            "id": "string",
            "user_id": "string",
            "file_path": "string",
            "original_name": "string",
            "mime_type": "string",
            "file_type": "string",
            "file_size": "number",
            "uploaded_at": "string"
          }
        }
      }
    },
    {
      "name": "Reject unsupported file type",
      "headers": {
        "Authorization": "Bearer {{cache:auth.register.response.data.token}}",
        "Content-Type": "multipart/form-data"
      },
      "payload": {
        "file": "{{dynamic:file_invalid}}"
      },
      "expectedStatus": 400,
      "expectedResponse": {
        "success": false,
        "error": "string"
      }
    }
  ]
}
