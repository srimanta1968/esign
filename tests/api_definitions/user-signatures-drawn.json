{
  "endpoint": "/api/user-signatures",
  "method": "POST",
  "taskId": "33da9a0b-9267-4d4a-b978-1c3bc346dd08",
  "requiresAuth": true,
  "priority": 30,
  "dependsOn": ["POST /api/auth/register"],
  "captureResponse": {
    "userSignatures.createDrawn.response.data.userSignature.id": "data.userSignature.id"
  },
  "testCases": [
    {
      "name": "Create a drawn signature from base64 PNG data",
      "headers": {
        "Authorization": "Bearer {{cache:auth.register.response.data.token}}",
        "Content-Type": "application/json"
      },
      "payload": {
        "signature_type": "drawn",
        "signature_data": "data:image/png;base64,iVBORw0KGgoAAAANSUhEUgAAAAEAAAABCAYAAAAfFcSJAAAADUlEQVR42mNk+M9QDwADhgGAWjR9awAAAABJRU5ErkJggg==",
        "input_method": "mouse"
      },
      "expectedStatus": 201,
      "expectedResponse": {
        "success": true,
        "data": {
          "userSignature": {
            "id": "string",
            "user_id": "string",
            "signature_type": "drawn",
            "signature_data": "string",
            "signature_image_path": "string"
          }
        }
      }
    },
    {
      "name": "Create a drawn signature with touch input",
      "headers": {
        "Authorization": "Bearer {{cache:auth.register.response.data.token}}",
        "Content-Type": "application/json"
      },
      "payload": {
        "signature_type": "drawn",
        "signature_data": "data:image/png;base64,iVBORw0KGgoAAAANSUhEUgAAAAEAAAABCAYAAAAfFcSJAAAADUlEQVR42mNk+M9QDwADhgGAWjR9awAAAABJRU5ErkJggg==",
        "input_method": "touch"
      },
      "expectedStatus": 201,
      "expectedResponse": {
        "success": true,
        "data": {
          "userSignature": {
            "id": "string",
            "user_id": "string",
            "signature_type": "drawn"
          }
        }
      }
    },
    {
      "name": "Fail to create drawn signature without signature_data",
      "headers": {
        "Authorization": "Bearer {{cache:auth.register.response.data.token}}",
        "Content-Type": "application/json"
      },
      "payload": {
        "signature_type": "drawn"
      },
      "expectedStatus": 400,
      "expectedResponse": {
        "success": false,
        "error": "string"
      }
    }
  ]
}
