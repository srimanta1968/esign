{
  "name": "POST /api/documents/:id/tags - Add tags",
  "endpoint": "/api/documents/{{cache:documents.upload.response.data.id}}/tags",
  "method": "POST",
  "requiresAuth": true,
  "expectedStatus": 201,
  "taskId": "ad4ab56b-fb79-4d6e-9ab7-e598befdf828",
  "sprintId": "729f9fe5-b963-4444-8b0e-f82bd555d110",
  "testCases": [
    {
      "name": "Add tags to document",
      "payload": {
        "tags": ["important", "legal"]
      },
      "expectedStatus": 201,
      "headers": {
        "Authorization": "Bearer {{cache:auth.login.response.data.token}}"
      }
    },
    {
      "name": "Empty tags array",
      "payload": {
        "tags": []
      },
      "expectedStatus": 400,
      "headers": {
        "Authorization": "Bearer {{cache:auth.login.response.data.token}}"
      }
    }
  ],
  "dependsOn": ["POST /api/auth/register", "POST /api/auth/login", "POST /api/documents"]
}
