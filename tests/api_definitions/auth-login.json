{
  "endpoint": "/api/auth/login",
  "method": "POST",
  "taskId": "9927c6cb-2af2-438a-b9cd-f7f35ff9e6a2",
  "requiresAuth": false,
  "priority": 2,
  "dependsOn": ["POST /api/auth/register"],
  "captureResponse": {
    "auth.login.response.data.token": "data.token",
    "auth.login.response.data.user.id": "data.user.id"
  },
  "testCases": [
    {
      "name": "Login with valid credentials",
      "headers": {
        "Content-Type": "application/json"
      },
      "payload": {
        "email": "{{cache:auth.register.response.data.user.email}}",
        "password": "TestPass@1234"
      },
      "expectedStatus": 200,
      "expectedResponse": {
        "success": true,
        "data": {
          "token": "string",
          "user": {
            "id": "string",
            "email": "string"
          }
        }
      }
    }
  ]
}
