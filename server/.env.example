# Environment Configuration for EXPRESS
# Generated for I want to build app similar
# Copy this file to .env and configure your values

# ============================================
# APPLICATION CONFIGURATION
# ============================================

NODE_ENV=development
PORT=3000
APP_NAME=I want to build app similar
API_PREFIX=/api
API_VERSION=v1

# ============================================
# DATABASE CONFIGURATION (POSTGRESQL)
# ============================================
# These defaults work with docker-compose.yml
DB_HOST=localhost
DB_PORT=5432
DB_NAME=edocs_db
DB_USER=postgres
DB_PASSWORD=postgres

# Connection string (alternative to individual vars)
DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}

# ============================================
# EXPRESS SPECIFIC
# ============================================
# Express.js Settings
BODY_PARSER_LIMIT=10mb
TRUST_PROXY=false

# ============================================
# SECURITY & AUTHENTICATION
# ============================================

JWT_SECRET=your_jwt_secret_key_change_this_in_production
JWT_EXPIRES_IN=7d
BCRYPT_ROUNDS=10

# ============================================
# CORS CONFIGURATION
# ============================================
CORS_ORIGIN=http://localhost:3000,http://localhost:5173
CORS_METHODS=GET,POST,PUT,DELETE,PATCH
CORS_CREDENTIALS=true

# ============================================
# RATE LIMITING
# ============================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ============================================
# LOGGING
# ============================================
LOG_LEVEL=debug
LOG_FORMAT=dev

# ============================================
# OPTIONAL SERVICES (uncomment if needed)
# ============================================

# Email Configuration
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USER=your_email@gmail.com
# EMAIL_PASSWORD=your_email_password

# AWS S3 Storage
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=your_access_key
# AWS_SECRET_ACCESS_KEY=your_secret_key
# S3_BUCKET=your_bucket_name

# Redis Cache
# REDIS_CACHE_HOST=localhost
# REDIS_CACHE_PORT=6379

# ============================================
# IMPORTANT NOTES
# ============================================

# 1. NEVER commit the .env file to version control
# 2. Add .env to your .gitignore file
# 3. Use strong, unique passwords for production
# 4. Update JWT_SECRET with a secure random string
# 5. Configure database credentials before running the application
