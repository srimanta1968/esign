{
  "name": "POST /api/documents - Upload document",
  "endpoint": "/api/documents",
  "method": "POST",
  "requiresAuth": true,
  "expectedStatus": 201,
  "taskId": "ad4ab56b-fb79-4d6e-9ab7-e598befdf828",
  "sprintId": "729f9fe5-b963-4444-8b0e-f82bd555d110",
  "contentType": "multipart/form-data",
  "testCases": [
    {
      "name": "Upload a PDF document",
      "payload": {
        "file": "@fixture:sample.pdf"
      },
      "expectedStatus": 201,
      "headers": {
        "Authorization": "Bearer {{cache:auth.login.response.data.token}}"
      }
    },
    {
      "name": "Upload without file",
      "expectedStatus": 400,
      "headers": {
        "Authorization": "Bearer {{cache:auth.login.response.data.token}}"
      }
    }
  ],
  "captureResponse": {
    "documents.upload.response.data.id": "data.document.id"
  },
  "dependsOn": ["POST /api/auth/register", "POST /api/auth/login"]
}
