        "type": "{{static:system}}",
        "message": "{{dynamic:text}}",
        "channels": [
          "in_app"
        ]
      },
      "expectedStatus": 200
    }
  ],
  "dependsOn": [
    "POST /api/auth/register",
    "POST /api/auth/login"
  ],
