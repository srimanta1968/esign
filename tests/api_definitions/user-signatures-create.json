{
  "endpoint": "/api/user-signatures",
  "method": "POST",
  "taskId": "f2e996a5-6c35-4899-8965-d5fd4afad095",
  "requiresAuth": true,
  "priority": 30,
  "dependsOn": ["POST /api/auth/register"],
  "captureResponse": {
    "userSignatures.create.response.data.userSignature.id": "data.userSignature.id"
  },
  "testCases": [
    {
      "name": "Create a user signature",
      "headers": {
        "Authorization": "Bearer {{cache:auth.register.response.data.token}}",
        "Content-Type": "application/json"
      },
      "payload": {
        "signature_type": "{{dynamic:text}}"
      },
      "expectedStatus": 201,
      "expectedResponse": {
        "success": true,
        "data": {
          "userSignature": {
            "id": "string",
            "user_id": "string",
            "signature_type": "string"
          }
        }
      }
    }
  ]
}
