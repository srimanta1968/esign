{
  "endpoint": "/api/signatures/:id/sign",
  "method": "PATCH",
  "taskId": "f2e996a5-6c35-4899-8965-d5fd4afad095",
  "requiresAuth": true,
  "priority": 22,
  "dependsOn": ["POST /api/auth/register", "POST /api/documents", "POST /api/signatures"],
  "captureResponse": {},
  "testCases": [
    {
      "name": "Sign a document",
      "headers": {
        "Authorization": "Bearer {{cache:auth.register.response.data.token}}",
        "Content-Type": "application/json"
      },
      "pathParams": {
        "id": "{{cache:signatures.create.response.data.signature.id}}"
      },
      "payload": {
        "user_signature_id": "{{cache:userSignatures.create.response.data.userSignature.id}}"
      },
      "expectedStatus": 200,
      "expectedResponse": {
        "success": true,
        "data": {
          "signature": {
            "id": "string",
            "status": "string"
          }
        }
      }
    }
  ]
}
