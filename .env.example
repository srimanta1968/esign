# Environment Configuration
# Copy this file to .env and fill in your values

# ============================================
# APPLICATION CONFIGURATION
# ============================================
NODE_ENV=development
PORT=3002

# ============================================
# DATABASE CONFIGURATION
# ============================================
# Database: postgresql
# PostgreSQL Configuration (matches docker-compose.yml defaults)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=edocs_db
DB_USER=postgres
DB_PASSWORD=postgres
DB_SSL=false
DB_POOL_MIN=2
DB_POOL_MAX=10

# ⚡ Quick Start: These defaults work with docker-compose.yml
# Just run: cp .env.example .env && docker-compose up -d

# ============================================
# SECURITY & AUTHENTICATION
# ============================================
JWT_SECRET=your_jwt_secret_key_change_this_in_production
JWT_EXPIRES_IN=7d
BCRYPT_ROUNDS=10

# ============================================
# EXPRESS CONFIGURATION
# ============================================
CORS_ORIGIN=http://localhost:3000
RATE_LIMIT_WINDOW=15m
RATE_LIMIT_MAX=100

# ============================================
# TESTING CONFIGURATION
# ============================================
TEST_DB_NAME=i_want_to_build_app_similar_test
TEST_DB_HOST=localhost
TEST_DB_PORT=5432

# ============================================
# LOGGING CONFIGURATION
# ============================================
LOG_LEVEL=debug
LOG_FORMAT=json

# ============================================
# OPTIONAL SERVICES (uncomment if needed)
# ============================================
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USER=your_email@gmail.com
# EMAIL_PASSWORD=your_email_password

# ============================================
# GOOGLE OAUTH
# ============================================
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:3002/api/auth/sso/callback

# ============================================
# LINKEDIN OAUTH
# ============================================
LINKEDIN_CLIENT_ID=your_linkedin_client_id
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret
LINKEDIN_REDIRECT_URI=http://localhost:3002/api/auth/sso/callback

# ============================================
# AWS S3 DOCUMENT STORAGE
# ============================================
# Required for S3 storage. Falls back to local disk if not set.
AWS_REGION=us-east-1
S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
S3_BUCKET=your_bucket_name
S3_PREFIX=edocs

# REDIS_CACHE_HOST=localhost
# REDIS_CACHE_PORT=6379

# ============================================
# IMPORTANT NOTES
# ============================================
# 1. NEVER commit the .env file to version control
# 2. Add .env to your .gitignore file
# 3. Use strong, unique passwords for production
# 4. Update JWT_SECRET with a secure random string
# 5. Configure database credentials before running the application

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# ProjexLight MCP Server Configuration
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# These variables are auto-generated from encrypted config (mcp-config.json)
# DO NOT edit PROJEXLIGHT_* variables - they will be overwritten
# You CAN edit MODEL_OVERRIDE_* variables to customize LLM models

# Platform API (Auto-generated - DO NOT EDIT)
# URL is set based on server environment: dev.projexlight.com (dev) or api.projexlight.com (prod)
PROJEXLIGHT_API_URL=https://api.projexlight.com
PROJEXLIGHT_API_KEY=<will_be_decrypted_from_mcp-config.json>
PROJEXLIGHT_PROJECT_ID=30229b2b-ea03-42c5-9b18-3ce752826417

# LLM Configuration (Auto-generated defaults)
LLM_PROVIDER=<will_be_decrypted>
LLM_API_KEY=<will_be_decrypted>
LLM_MODEL_REVIEW=<will_be_decrypted>
LLM_MODEL_EMBEDDING=<will_be_decrypted>
LLM_MODEL_AUTOFIX=<will_be_decrypted>
LLM_MAX_TOKENS=4000
LLM_TEMPERATURE=0.1

# Model Overrides (OPTIONAL - Uncomment to override tenant defaults)
# Validate compatibility with provider before uncommenting!
# MODEL_OVERRIDE_REVIEW=gpt-3.5-turbo
# MODEL_OVERRIDE_EMBEDDING=text-embedding-3-small
# MODEL_OVERRIDE_AUTOFIX=claude-3-sonnet-20240229

# MCP Server Settings
MCP_SERVER_PORT=8766
MCP_LOG_LEVEL=INFO
MCP_AUTO_FIX_ENABLED=true
MCP_COMPLIANCE_THRESHOLD=80

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Schema Sync Agent Configuration (Multi-Developer Sync)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Enable schema sync agent to automatically detect and sync database changes
# across multiple developer containers

# Enable/disable schema sync agent (default: true)
SCHEMA_SYNC_ENABLED=true

# How often to check for schema changes (in seconds, default: 30)
SCHEMA_SYNC_INTERVAL=30

# Auto-apply incoming migrations from other developers (default: false)
# Set to true to automatically apply schema changes without manual approval
# WARNING: Set to false in production for manual review of changes
AUTO_APPLY_MIGRATIONS=false

# Developer identifier (auto-generated if empty, can be overridden)
# This uniquely identifies your local development environment
# Example: DEVELOPER_ID=john-doe or DEVELOPER_ID=dev-container-1
DEVELOPER_ID=

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
