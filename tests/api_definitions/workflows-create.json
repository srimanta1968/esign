{
  "name": "POST /api/workflows - Create signing workflow",
  "endpoint": "/api/workflows",
  "method": "POST",
  "requiresAuth": true,
  "expectedStatus": 201,
  "taskId": "2bee76ea-823d-4c9b-b6ed-312b00dc487e",
  "sprintId": "729f9fe5-b963-4444-8b0e-f82bd555d110",
  "testCases": [
    {
      "name": "Create a new workflow with recipients",
      "payload": {
        "document_id": "{{cache:documents.upload.response.data.id}}",
        "name": "Contract Signing",
        "mode": "sequential",
        "recipients": [
          {
            "signer_email": "a_{{timestamp}}@example.com",
            "signer_name": "Signer A",
            "signing_order": 1,
            "role": "signer"
          }
        ]
      },
      "expectedStatus": 201,
      "headers": {
        "Authorization": "Bearer {{cache:auth.login.response.data.token}}"
      }
    }
  ],
  "captureResponse": {
    "workflows.create.response.data.id": "data.workflow.id"
  },
  "dependsOn": ["POST /api/auth/register", "POST /api/auth/login", "POST /api/documents"]
}
