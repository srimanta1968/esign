{
  "endpoint": "/api/auth/forgot-password",
  "method": "POST",
  "taskId": "56b4c7eb-2323-4cf3-b34f-828299c78420",
  "requiresAuth": false,
  "priority": 3,
  "dependsOn": ["POST /api/auth/register"],
  "captureResponse": {
    "auth.forgotPassword.response.data.resetToken": "data.resetToken"
  },
  "testCases": [
    {
      "name": "Request password reset for existing email",
      "headers": {
        "Content-Type": "application/json"
      },
      "payload": {
        "email": "{{captured:auth.register.response.data.user.email}}"
      },
      "expectedStatus": 200,
      "expectedResponse": {
        "success": true,
        "data": {
          "message": "string",
          "resetToken": "string"
        }
      }
    },
    {
      "name": "Request password reset for non-existing email (still returns 200)",
      "headers": {
        "Content-Type": "application/json"
      },
      "payload": {
        "email": "nonexistent@example.com"
      },
      "expectedStatus": 200,
      "expectedResponse": {
        "success": true,
        "data": {
          "message": "string"
        }
      }
    }
  ]
}
