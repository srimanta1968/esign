{
  "taskId": "a4be70f6-af3b-4838-80f7-b7f69a4660af",
  "endpoint": "POST /api/notifications/send",
  "description": "Send a notification via specified channels (email, sms, in_app) with delivery logging",
  "auth": "Bearer JWT",
  "request": {
    "method": "POST",
    "path": "/api/notifications/send",
    "headers": {
      "Authorization": "Bearer <jwt_token>",
      "Content-Type": "application/json"
    },
    "body": {
      "userId": "uuid",
      "type": "signature_requested | signature_completed | document_shared | reminder | system",
      "message": "string",
      "channels": ["email", "sms", "in_app"],
      "actionUrl": "string (optional)"
    }
  },
  "response": {
    "success": {
      "status": 200,
      "body": {
        "success": true,
        "data": {
          "notification": {
            "id": "uuid",
            "user_id": "uuid",
            "type": "string",
            "message": "string",
            "is_read": false,
            "action_url": "string | null",
            "created_at": "ISO 8601 timestamp"
          },
          "deliveries": [
            {
              "channel": "email | sms | in_app",
              "status": "sent | failed | skipped",
              "error": "string (optional)"
            }
          ]
        }
      }
    },
    "error_400": {
      "status": 400,
      "body": {
        "success": false,
        "error": "Missing required fields: userId, type, message, channels (array)"
      }
    },
    "error_401": {
      "status": 401,
      "body": {
        "success": false,
        "error": "Access token required"
      }
    }
  },
  "tables": {
    "notification_delivery_log": {
      "columns": {
        "id": "UUID PRIMARY KEY",
        "notification_id": "UUID NOT NULL REFERENCES notifications(id)",
        "channel": "VARCHAR(20) NOT NULL (email/sms/in_app)",
        "recipient": "VARCHAR(255) NOT NULL",
        "status": "VARCHAR(20) NOT NULL (pending/sent/failed)",
        "sent_at": "TIMESTAMP WITH TIME ZONE (nullable)",
        "error_message": "TEXT (nullable)",
        "created_at": "TIMESTAMP WITH TIME ZONE"
      }
    }
  }
}
