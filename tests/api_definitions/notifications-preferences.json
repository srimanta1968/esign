{
  "taskId": "1e6be6b1-05c2-4254-9a04-57c3c55ab625",
  "endpoints": [
    {
      "endpoint": "GET /api/notifications/preferences",
      "description": "Get notification preferences for authenticated user",
      "auth": "Bearer JWT",
      "request": {
        "method": "GET",
        "path": "/api/notifications/preferences",
        "headers": {
          "Authorization": "Bearer <jwt_token>"
        }
      },
      "response": {
        "success": {
          "status": 200,
          "body": {
            "success": true,
            "data": {
              "preferences": [
                {
                  "notification_type": "signature_requested",
                  "email_enabled": true,
                  "sms_enabled": true,
                  "in_app_enabled": true
                },
                {
                  "notification_type": "signature_completed",
                  "email_enabled": true,
                  "sms_enabled": true,
                  "in_app_enabled": true
                },
                {
                  "notification_type": "document_shared",
                  "email_enabled": true,
                  "sms_enabled": true,
                  "in_app_enabled": true
                },
                {
                  "notification_type": "reminder",
                  "email_enabled": true,
                  "sms_enabled": true,
                  "in_app_enabled": true
                },
                {
                  "notification_type": "system",
                  "email_enabled": true,
                  "sms_enabled": true,
                  "in_app_enabled": true
                }
              ]
            }
          }
        },
        "error_401": {
          "status": 401,
          "body": {
            "success": false,
            "error": "Access token required"
          }
        }
      }
    },
    {
      "endpoint": "PUT /api/notifications/preferences",
      "description": "Update notification preferences (bulk update for all types)",
      "auth": "Bearer JWT",
      "request": {
        "method": "PUT",
        "path": "/api/notifications/preferences",
        "headers": {
          "Authorization": "Bearer <jwt_token>",
          "Content-Type": "application/json"
        },
        "body": {
          "preferences": [
            {
              "notification_type": "signature_requested | signature_completed | document_shared | reminder | system",
              "email_enabled": "boolean",
              "sms_enabled": "boolean",
              "in_app_enabled": "boolean"
            }
          ]
        }
      },
      "response": {
        "success": {
          "status": 200,
          "body": {
            "success": true,
            "message": "Notification preferences updated successfully",
            "data": {
              "preferences": []
            }
          }
        },
        "error_400": {
          "status": 400,
          "body": {
            "success": false,
            "error": "Missing required field: preferences (array)"
          }
        },
        "error_401": {
          "status": 401,
          "body": {
            "success": false,
            "error": "Access token required"
          }
        }
      }
    }
  ],
  "tables": {
    "notification_preferences": {
      "columns": {
        "id": "UUID PRIMARY KEY",
        "user_id": "UUID NOT NULL",
        "notification_type": "VARCHAR(50) NOT NULL",
        "email_enabled": "BOOLEAN DEFAULT true",
        "sms_enabled": "BOOLEAN DEFAULT true",
        "in_app_enabled": "BOOLEAN DEFAULT true",
        "created_at": "TIMESTAMP WITH TIME ZONE",
        "updated_at": "TIMESTAMP WITH TIME ZONE"
      },
      "constraints": "UNIQUE(user_id, notification_type)"
    }
  },
  "default_preferences": "All channels enabled for all types: signature_requested, signature_completed, document_shared, reminder, system"
}
