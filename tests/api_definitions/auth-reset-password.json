{
  "endpoint": "/api/auth/reset-password",
  "method": "POST",
  "taskId": "56b4c7eb-2323-4cf3-b34f-828299c78420",
  "requiresAuth": false,
  "priority": 4,
  "dependsOn": ["POST /api/auth/forgot-password"],
  "testCases": [
    {
      "name": "Reset password with valid token",
      "headers": {
        "Content-Type": "application/json"
      },
      "payload": {
        "token": "{{cache:auth.forgotPassword.response.data.resetToken}}",
        "password": "NewPass@1234"
      },
      "expectedStatus": 200,
      "expectedResponse": {
        "success": true,
        "data": {
          "message": "Password has been reset successfully"
        }
      }
    },
    {
      "name": "Reject invalid reset token",
      "headers": {
        "Content-Type": "application/json"
      },
      "payload": {
        "token": "invalid-token-value",
        "password": "NewPass@1234"
      },
      "expectedStatus": 400,
      "expectedResponse": {
        "success": false,
        "error": "Invalid reset token"
      }
    }
  ]
}
