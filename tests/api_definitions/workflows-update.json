{
  "endpoint": "/api/workflows/:id",
  "method": "PUT",
  "taskId": "c49c5e95-5e92-4d5d-adb6-9c9ccc99c2bf",
  "requiresAuth": true,
  "priority": 32,
  "dependsOn": ["POST /api/workflows"],
  "testCases": [
    {
      "name": "Update workflow recipients and fields",
      "headers": {
        "Authorization": "Bearer {{cache:auth.register.response.data.token}}",
        "Content-Type": "application/json"
      },
      "urlParams": {
        "id": "{{cache:workflows.create.response.data.workflow.id}}"
      },
      "payload": {
        "recipients": [
          {
            "signer_email": "{{dynamic:email}}",
            "signer_name": "Updated Signer 1",
            "signing_order": 1
          }
        ]
      },
      "expectedStatus": 200,
      "expectedResponse": {
        "success": true,
        "data": {
          "workflow": {
            "id": "string",
            "status": "string",
            "recipients": "array"
          }
        }
      }
    }
  ]
}
