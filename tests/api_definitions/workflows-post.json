{
  "name": "POST /api/workflows",
  "endpoint": "/api/workflows",
  "method": "POST",
  "requiresAuth": true,
  "expectedStatus": 201,
  "taskId": "c49c5e95-5e92-4d5d-adb6-9c9ccc99c2bf",
  "sprintId": "729f9fe5-b963-4444-8b0e-f82bd555d110",
  "featureId": "8cdff6b0-8040-47aa-a789-421101b7f41a",
  "priority": 10,
  "dependsOn": [
    "POST /api/auth/register",
    "POST /api/auth/login",
    "POST /api/documents"
  ],
  "testCases": [
    {
      "name": "Create a signing workflow with recipients",
      "payload": {
        "document_id": "{{cache:documents.create.response.data.document.id}}",
        "workflow_type": "{{static:sequential}}",
        "recipients": [
          {
            "signer_name": "{{dynamic:name}}",
            "signer_email": "{{dynamic:email}}",
            "signing_order": 1
          },
          {
            "signer_name": "{{dynamic:name}}",
            "signer_email": "{{dynamic:email}}",
            "signing_order": 2
          }
        ],
        "fields": [
          {
            "x": 100,
            "y": 500,
            "page": 1,
            "width": 200,
            "height": 50,
            "field_type": "signature",
            "recipient_index": 0
          }
        ]
      },
      "expectedStatus": 201,
      "headers": {
        "Content-Type": "application/json",
        "Authorization": "Bearer {{cache:auth.login.response.data.token}}"
      },
      "expectedResponse": {
        "success": true
      }
    }
  ],
  "captureResponse": {
    "workflows.create.response.data.workflow.id": "data.workflow.id"
  }
}
