{
  "name": "POST /api/signatures - Create signature request",
  "endpoint": "/api/signatures",
  "method": "POST",
  "requiresAuth": true,
  "expectedStatus": 201,
  "taskId": "2bee76ea-823d-4c9b-b6ed-312b00dc487e",
  "sprintId": "729f9fe5-b963-4444-8b0e-f82bd555d110",
  "testCases": [
    {
      "name": "Create a signature request on a document",
      "payload": {
        "document_id": "{{cache:documents.upload.response.data.id}}",
        "signer_email": "signer_{{timestamp}}@example.com",
        "signer_name": "Signer"
      },
      "expectedStatus": 201,
      "headers": {
        "Authorization": "Bearer {{cache:auth.login.response.data.token}}"
      }
    },
    {
      "name": "Missing document_id",
      "payload": {
        "signer_email": "missing@example.com"
      },
      "expectedStatus": 400,
      "headers": {
        "Authorization": "Bearer {{cache:auth.login.response.data.token}}"
      }
    }
  ],
  "captureResponse": {
    "signatures.create.response.data.id": "data.signature.id"
  },
  "dependsOn": ["POST /api/auth/register", "POST /api/auth/login", "POST /api/documents"]
}
